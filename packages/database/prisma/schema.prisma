generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  PARTNER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MembershipType {
  FREE
  PREMIUM
  STUDENT
  WORKER
}

enum PartnerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  CUSTOM
}

enum VisitMethod {
  QR_SCAN
  MANUAL
  PARTNER_VALIDATION
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
  PENDING
  REJECTED
}

enum BannerStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum VoucherStatus {
  ISSUED
  PAID
  REDEEMED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum PartnerPayoutStatus {
  NOT_DUE
  PENDING
  PAID
  FAILED
  CANCELLED
}

model User {
  id             String     @id @default(cuid())
  supabaseAuthId String?    @unique
  email          String     @unique
  phone          String?    @unique
  fullName       String
  dateOfBirth    DateTime?
  profilePhoto   String?
  language       String     @default("en")
  role           UserRole   @default(USER)
  status         UserStatus @default(ACTIVE)
  homeCountry    Country?   @relation(fields: [homeCountryId], references: [id], onDelete: SetNull)
  homeCountryId  String?

  memberships     Membership[]
  partnerAccounts PartnerUser[]
  visits          PartnerVisit[] @relation("VisitUser")
  scannedVisits   PartnerVisit[] @relation("VisitScanner")
  reviews         Review[]
  vouchers        Voucher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([homeCountryId])
}

model Membership {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  type                        MembershipType @default(FREE)
  isManuallyGranted           Boolean        @default(false)
  revenueCatCustomerId        String?
  revenueCatEntitlement       String?
  revenueCatProductId         String?
  revenueCatOriginalAppUserId String?
  currentPeriodStart          DateTime?
  currentPeriodEnd            DateTime?
  cancelledAt                 DateTime?
  expiresAt                   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([revenueCatCustomerId])
}

model Country {
  id String @id @default(cuid())

  name      String
  code      String  @unique
  phoneCode String?
  currency  String?
  active    Boolean @default(true)

  // Apex Card availability — independent of `active` (global/master-data status).
  // A country can be a valid choice for user nationality/residence while remaining
  // unavailable for Partners and hidden from the mobile Explore screen.
  availableForPartners Boolean @default(false)
  visibleInExplore     Boolean @default(false)
  featured             Boolean @default(false)
  displayOrder         Int     @default(0)
  region               String?

  // Destination media for the mobile Explore screen (Supabase Storage object path,
  // not a generated public URL — see packages/api/src/lib/supabaseAdmin.ts).
  imagePath    String?
  imageAltText String?

  cities       City[]
  users        User[]
  partners     Partner[]
  promoBanners PromoBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([availableForPartners])
  @@index([visibleInExplore])
}

model City {
  id String @id @default(cuid())

  name   String
  slug   String
  active Boolean @default(true)

  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  countryId String

  partners     Partner[]
  promoBanners PromoBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, slug])
  @@index([active])
}

model Category {
  id String @id @default(cuid())

  name   String
  slug   String  @unique
  icon   String?
  active Boolean @default(true)

  partnerCategories PartnerCategory[]
  promoBanners      PromoBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model Partner {
  id String @id @default(cuid())

  name         String
  slug         String        @unique
  description  String?
  email        String?
  phone        String?
  whatsapp     String?
  website      String?
  addressLine1 String?
  addressLine2 String?
  postalCode   String?
  // Preferred way for the mobile app to open navigation — validated as a Google Maps link.
  googleMapsUrl String?
  latitude     Decimal?      @db.Decimal(9, 6)
  longitude    Decimal?      @db.Decimal(9, 6)
  status       PartnerStatus @default(DRAFT)

  country    Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  countryId  String
  city   City?   @relation(fields: [cityId], references: [id], onDelete: SetNull)
  cityId String?

  users        PartnerUser[]
  categories   PartnerCategory[]
  media        PartnerMedia[]
  benefits     Benefit[]
  visits       PartnerVisit[]
  reviews      Review[]
  vouchers     Voucher[]
  promoBanners PromoBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([cityId])
  @@index([status])
}

// Many-to-many Partner <-> Category. One physical location per Partner is an intentional
// MVP decision (a multi-branch business registers each branch as its own Partner), so
// categories attach directly to the Partner, not to a location entity.
model PartnerCategory {
  id String @id @default(cuid())

  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId  String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId String

  createdAt DateTime @default(now())

  @@unique([partnerId, categoryId])
  @@index([categoryId])
}

model PartnerMedia {
  id String @id @default(cuid())

  // Stable Supabase Storage object path in the public "partner-assets" bucket
  // (partners/{partnerId}/{uuid}.{ext}) — never a bare public URL.
  storagePath String
  mimeType    String
  isCover     Boolean @default(false)
  sortOrder   Int     @default(0)

  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
}

model PartnerUser {
  id String @id @default(cuid())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String
  title     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, partnerId])
  @@index([partnerId])
}

model Benefit {
  id String @id @default(cuid())

  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String

  title       String
  description String?
  type        DiscountType @default(CUSTOM)
  value       Decimal?     @db.Decimal(10, 2)
  currency    String?
  terms       String?
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?

  visits   PartnerVisit[]
  vouchers Voucher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
  @@index([isActive])
  @@index([startsAt, endsAt])
}

model PartnerVisit {
  id String @id @default(cuid())

  user        User        @relation("VisitUser", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  partner     Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId   String
  benefit     Benefit?    @relation(fields: [benefitId], references: [id], onDelete: SetNull)
  benefitId   String?
  method      VisitMethod
  scannedBy   User?       @relation("VisitScanner", fields: [scannedById], references: [id], onDelete: SetNull)
  scannedById String?
  notes       String?
  visitedAt   DateTime    @default(now())

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([partnerId])
  @@index([benefitId])
  @@index([scannedById])
  @@index([visitedAt])
}

model Review {
  id String @id @default(cuid())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String

  rating  Int
  comment String?
  status  ReviewStatus @default(VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, partnerId])
  @@index([partnerId])
  @@index([status])
}

model PromoBanner {
  id String @id @default(cuid())

  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  status    BannerStatus @default(DRAFT)
  startsAt  DateTime?
  endsAt    DateTime?
  sortOrder Int          @default(0)

  country    Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  countryId  String?
  city       City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  cityId     String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?
  partner    Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  partnerId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startsAt, endsAt])
  @@index([countryId])
  @@index([cityId])
}

model Voucher {
  id String @id @default(cuid())

  code      String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  partnerId String
  benefit   Benefit? @relation(fields: [benefitId], references: [id], onDelete: SetNull)
  benefitId String?

  title          String
  description    String?
  totalAmount    Decimal             @db.Decimal(10, 2)
  partnerAmount  Decimal             @db.Decimal(10, 2)
  apexCommission Decimal             @db.Decimal(10, 2)
  currency       String              @default("EUR")
  status         VoucherStatus       @default(ISSUED)
  payoutStatus   PartnerPayoutStatus @default(NOT_DUE)

  paymentProvider  String?
  paymentReference String?
  redeemedAt       DateTime?
  redeemedBy       String?
  redemptionNotes  String?
  expiresAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([partnerId])
  @@index([benefitId])
  @@index([status])
  @@index([payoutStatus])
  @@index([expiresAt])
}
