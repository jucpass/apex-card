# Root environment example.
# Copy to .env for local development and replace placeholder values.
# Do not commit real .env values.

# Server-only: Prisma uses the transaction-mode pooler at runtime.
DATABASE_URL="postgresql://postgres.fofiwolcfspmacbgclfy:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Server-only: Prisma uses the direct connection for migrations.
DIRECT_URL="postgresql://postgres.fofiwolcfspmacbgclfy:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Used by the API to validate Supabase access tokens.
# Safe to expose only where a public Supabase client is intended.
SUPABASE_URL="https://fofiwolcfspmacbgclfy.supabase.co"
SUPABASE_PUBLISHABLE_KEY="[YOUR-SUPABASE-PUBLISHABLE-KEY]"

# Server-only secret. Never expose this to the Expo app, admin frontend, or browser bundles.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SUPABASE-SECRET-KEY]"

# Server-only bootstrap guard. The first matching Supabase user can be linked or created as SUPER_ADMIN.
FIRST_SUPER_ADMIN_EMAIL="[YOUR-FIRST-SUPER-ADMIN-EMAIL]"

NODE_ENV="development"
API_PORT=4000
